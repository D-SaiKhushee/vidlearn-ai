# ── VidLearn AI — Backend Environment Variables ───────────────────────────────

# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Generate a strong random secret — run this in terminal to get one:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# Database — SQLite by default (file created automatically, no setup needed)
# For Azure PostgreSQL, replace with:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./vidlearn.db
